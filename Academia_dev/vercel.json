{
  "version": 2,
  "builds": [
    {
      "src": "gemini-proxy.js",
      "use": "@vercel/node"
    },
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/gemini-proxy.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
